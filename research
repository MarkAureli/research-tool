def cmd_new() -> None:
    print("=== research new: Lean 4 + Mathlib project ===\n")

    name = prompt("Project name")

    reg = registry_load()
    if name in reg:
        print(
            f"Error: a project named '{name}' is already managed by this tool\n"
            f"  (at {reg[name]})\n"
            "Choose a different name or delete the existing project first.",
            file=sys.stderr,
        )
        sys.exit(1)

    parent_str = prompt("Parent directory", default="~/Research")
    question = prompt(
        "Research question",
        default="<!-- TODO: state the central mathematical question here -->",
    )
    visibility = pick("GitHub visibility", ["private", "public", "local"])
    author = get_or_prompt_author()

    parent = Path(parent_str).expanduser().resolve()
    parent.mkdir(parents=True, exist_ok=True)
    project_dir = parent / name

    if project_dir.exists():
        print(f"\nError: {project_dir} already exists.", file=sys.stderr)
        sys.exit(1)

    print(f"\nCreating {project_dir} …")
    project_dir.mkdir(parents=True)

    # Lean project scaffold (also runs git init internally)
    print("\nInitialising Lean project …")
    if not run(["lake", "init", name, "math"], cwd=project_dir):
        print("Error: lake init failed.", file=sys.stderr)
        sys.exit(1)

    # lake init math generates CI workflows we don't want — remove them
    shutil.rmtree(project_dir / ".github", ignore_errors=True)

    # Append our extra gitignore entry to what lake generated
    gitignore_path = project_dir / ".gitignore"
    with open(gitignore_path, "a") as f:
        f.write("/references/\n")

    # Write custom files
    today = date.today()

    files: dict[str, str] = {
        "LICENSE": build_apache_license(today.year, author),
        "CLAUDE.md": CLAUDE_MD.format(question=question),
        "HANDOFF.md": HANDOFF_MD.format(question=question, today=today.isoformat()),
        "AGENTS.md": AGENTS_MD,
        ".mcp.json": MCP_JSON,
    }

    for rel_path, content in files.items():
        path = project_dir / rel_path
        path.write_text(substitute(content, name))
        print(f"  wrote {rel_path}")

    # Create GitHub remote before bd init so beads can find the upstream
    has_remote = False
    if visibility == "local":
        pass  # no remote
    elif shutil.which("gh") is None:
        print(
            "\nNote: 'gh' not found — skipping GitHub step.\n"
            "To create the repo manually:\n"
            f"  cd {project_dir}\n"
            f"  gh repo create {name} --{visibility} --source=. --remote=origin --push"
        )
    else:
        print(f"\nCreating GitHub repo ({visibility}) …")
        has_remote = run(
            ["gh", "repo", "create", name, f"--{visibility}",
             "--source=.", "--remote=origin"],
            cwd=project_dir,
        )
        if not has_remote:
            print(
                "Warning: gh repo create failed.\n"
                "You can retry manually:\n"
                f"  cd {project_dir}\n"
                f"  gh repo create {name} --{visibility} --source=. --remote=origin --push",
                file=sys.stderr,
            )

    # beads task tracker (runs after remote is configured)
    if shutil.which("bd") is not None:
        print("\nInitialising beads task tracker …")
        run(["bd", "init"], cwd=project_dir)
    else:
        print("\nNote: 'bd' not found — skipping beads init.")
        print("Install beads: curl -fsSL https://raw.githubusercontent.com/steveyegge/beads/main/scripts/install.sh | bash")

    # af availability check (init requires a conjecture, so deferred to first use)
    if shutil.which("af") is None:
        print("\nNote: 'af' not found — install vibefeld for adversarial proof trees.")
        print("  https://github.com/MarkAureli/vibefeld")

    # Initial commit (includes beads files) + push
    run(["git", "add", "."], cwd=project_dir)
    run(["git", "commit", "-m", f"Initial scaffold for {name}"], cwd=project_dir)
    if has_remote:
        run(["git", "push", "-u", "origin", "HEAD"], cwd=project_dir)

    # Register
    registry_add(name, project_dir)

    print(f"\nDone!  Project created at:\n  {project_dir}\n")


def cmd_list() -> None:
    reg = registry_load()
    if not reg:
        print("No projects managed by this tool yet.")
        return
    for name, path in sorted(reg.items()):
        print(f"{name}\t{path}")


def cmd_delete(name: str) -> None:
    reg = registry_load()
    if name not in reg:
        print(f"Error: no project named '{name}' in the registry.", file=sys.stderr)
        sys.exit(1)

    project_dir = Path(reg[name])

    # Confirm
    print(f"Project : {name}")
    print(f"Path    : {project_dir}")
    remote = get_github_remote(project_dir) if project_dir.exists() else None
    if remote:
        print(f"Remote  : {remote}")
    suffix = " and GitHub repo" if remote else ""
    answer = input(f"\nPermanently delete local directory{suffix}? [y/N]: ").strip().lower()
    if answer != "y":
        print("Aborted.")
        return

    # Delete GitHub repo
    if remote:
        if shutil.which("gh") is None:
            print(
                "Note: 'gh' not found — cannot delete GitHub repo automatically.\n"
                f"Delete it manually at: {remote}"
            )
        else:
            print("Deleting GitHub repo …")
            ok = run(["gh", "repo", "delete", name, "--yes"])
            if not ok:
                print(
                    "Warning: GitHub repo deletion failed.\n"
                    "You may need to grant the delete_repo scope:\n"
                    "  gh auth refresh -h github.com -s delete_repo\n"
                    f"Then: gh repo delete {name} --yes",
                    file=sys.stderr,
                )

    # Delete local directory
    if project_dir.exists():
        print(f"Deleting {project_dir} …")
        shutil.rmtree(project_dir)
    else:
        print(f"Note: {project_dir} not found locally (already deleted?).")

    # Remove from registry
    registry_remove(name)
    print("Done.")


COMPLETION_SCRIPT = dedent("""\
    # research shell completion
    _research_complete() {
        local -a subcmds projects
        subcmds=(new list delete completion)
        if [[ $CURRENT -eq 2 ]]; then
            compadd -a subcmds
        elif [[ $CURRENT -eq 3 && $words[2] == delete ]]; then
            projects=($(research list 2>/dev/null | awk '{print $1}'))
            compadd -a projects
        fi
    }
    compdef _research_complete research
""")

COMPLETION_EVAL_LINE = 'eval "$(research completion)"'


def cmd_completion(install: bool = False) -> None:
    if not install:
        print(COMPLETION_SCRIPT)
        return

    zshrc = Path("~/.zshrc").expanduser()
    if zshrc.exists() and COMPLETION_EVAL_LINE in zshrc.read_text():
        print("Shell completion already configured in ~/.zshrc.")
        return
    with zshrc.open("a") as f:
        f.write(f"\n{COMPLETION_EVAL_LINE}\n")
    print("Shell completion added to ~/.zshrc.")
    print("Reload your shell or run:  source ~/.zshrc")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

USAGE = """\
Usage:
  research new                  scaffold a new project (interactive)
  research list                 list all managed projects
  research delete NAME          delete a project (local + GitHub)
  research completion           print shell completion script
  research completion install   add completion to ~/.zshrc
"""


def main() -> None:
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(USAGE)
        return

    cmd = args[0]

    if cmd == "new":
        cmd_new()
    elif cmd == "list":
        cmd_list()
    elif cmd == "delete":
        if len(args) < 2:
            print("Usage: research delete NAME", file=sys.stderr)
            sys.exit(1)
        cmd_delete(args[1])
    elif cmd == "completion":
        cmd_completion(install=len(args) > 1 and args[1] == "install")
    else:
        print(f"Unknown command: {cmd!r}\n{USAGE}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
