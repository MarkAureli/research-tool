#!/usr/bin/env python3
"""research — manage Lean 4 + Mathlib research projects.

Usage:
  research new              scaffold a new project (interactive)
  research list             list all managed projects
  research delete NAME      delete a project (local + GitHub)
  research completion       print shell completion script
"""

import json
import shutil
import subprocess
import sys
import termios
import tty
from datetime import date
from pathlib import Path
from textwrap import dedent


def pick(question: str, options: list[str]) -> str:
    """Render an arrow-key selection list; return the chosen option."""
    idx = 0
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        while True:
            sys.stdout.write(f"\r{question}\r\n")
            for i, opt in enumerate(options):
                prefix = "  > " if i == idx else "    "
                sys.stdout.write(f"{prefix}{opt}\r\n")
            sys.stdout.write(f"\033[{len(options) + 1}F\033[{len(question)}C")  # reposition cursor after question text
            sys.stdout.flush()

            ch = sys.stdin.read(1)
            if ch == "\x1b":
                sys.stdin.read(1)  # [
                arrow = sys.stdin.read(1)
                if arrow == "A":  # up
                    idx = (idx - 1) % len(options)
                elif arrow == "B":  # down
                    idx = (idx + 1) % len(options)
            elif ch in ("\r", "\n"):
                break
            elif ch == "\x03":  # Ctrl-C
                raise KeyboardInterrupt
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)

    # Clear the menu lines and print the final selection on one line
    sys.stdout.write(f"\r\033[J{question}: {options[idx]}\n")
    sys.stdout.flush()
    return options[idx]


# ---------------------------------------------------------------------------
# Config (persisted across projects — stores author name, etc.)
# ---------------------------------------------------------------------------

_STORE = Path.home() / ".local" / "share" / "research-tool"
REGISTRY_PATH = _STORE / "projects.json"
CONFIG_PATH   = _STORE / "config.json"


def config_load() -> dict:
    if not CONFIG_PATH.exists():
        return {}
    return json.loads(CONFIG_PATH.read_text())


def config_save(cfg: dict) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2) + "\n")


def get_or_prompt_author() -> str:
    cfg = config_load()
    if "author" in cfg:
        return cfg["author"]
    author = prompt("Author name (stored for future projects)")
    cfg["author"] = author
    config_save(cfg)
    return author


# ---------------------------------------------------------------------------
# Registry
# ---------------------------------------------------------------------------


def registry_load() -> dict[str, str]:
    if not REGISTRY_PATH.exists():
        return {}
    return json.loads(REGISTRY_PATH.read_text())


def registry_save(reg: dict[str, str]) -> None:
    REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
    REGISTRY_PATH.write_text(json.dumps(reg, indent=2) + "\n")


def registry_add(name: str, path: Path) -> None:
    reg = registry_load()
    reg[name] = str(path)
    registry_save(reg)


def registry_remove(name: str) -> None:
    reg = registry_load()
    reg.pop(name, None)
    registry_save(reg)


