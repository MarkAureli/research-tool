# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def prompt(msg: str, default: str = "") -> str:
    if default:
        val = input(f"{msg} [{default}]: ").strip()
        return val if val else default
    else:
        while True:
            val = input(f"{msg}: ").strip()
            if val:
                return val
            print("  (required — please enter a value)")


def run(args: list[str], cwd: Path | None = None) -> bool:
    """Run a subprocess; return True on success."""
    result = subprocess.run(args, cwd=cwd)
    return result.returncode == 0


def substitute(text: str, name: str) -> str:
    return text.replace("MyProject", name)


def get_github_remote(project_dir: Path) -> str | None:
    """Return the GitHub remote URL, or None if there isn't one."""
    result = subprocess.run(
        ["git", "remote", "get-url", "origin"],
        cwd=project_dir,
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        url = result.stdout.strip()
        if "github.com" in url:
            return url
    return None


