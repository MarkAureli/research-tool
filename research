_REQUIRED_TOOLS = {
    "elan": "https://leanprover.github.io/lean4/doc/setup.html",
    "lake": "https://leanprover.github.io/lean4/doc/setup.html",
    "git":  "https://git-scm.com/downloads",
    "bd":   "https://github.com/steveyegge/beads",
    "uvx":  "https://docs.astral.sh/uv/getting-started/installation/",
}


def _check_required_tools() -> None:
    missing = [
        (tool, url)
        for tool, url in _REQUIRED_TOOLS.items()
        if shutil.which(tool) is None
    ]
    if missing:
        lines = ["Error: required tools not found:"]
        for tool, url in missing:
            lines.append(f"  {tool}  →  {url}")
        print("\n".join(lines), file=sys.stderr)
        sys.exit(1)


def cmd_new(name: str = "") -> None:
    _check_required_tools()
    print("=== research new: Lean 4 + Mathlib project ===\n")

    if not name:
        name = prompt("Project name")

    reg = registry_load()
    if name in reg:
        print(
            f"Error: a project named '{name}' is already managed by this tool\n"
            f"  (at {reg[name]})\n"
            "Choose a different name or delete the existing project first.",
            file=sys.stderr,
        )
        sys.exit(1)

    parent_str = prompt("Parent directory", default="~/Research")
    visibility = pick("GitHub visibility", ["private", "public", "local"])
    author = get_or_prompt_author()

    parent = Path(parent_str).expanduser().resolve()
    parent.mkdir(parents=True, exist_ok=True)
    project_dir = parent / name

    if project_dir.exists():
        print(f"\nError: {project_dir} already exists.", file=sys.stderr)
        sys.exit(1)

    print(f"\nCreating {project_dir} …")
    project_dir.mkdir(parents=True)

    # Lean project scaffold (also runs git init internally)
    print("\nInitialising Lean project …")
    if not run(["lake", "init", name, "math"], cwd=project_dir):
        print("Error: lake init failed.", file=sys.stderr)
        sys.exit(1)

    # Fetch pre-built mathlib oleans (saves ~2 hours on first build)
    print("\nFetching Mathlib cache …")
    run(["lake", "exe", "cache", "get"], cwd=project_dir)

    # lake init math generates CI workflows we don't want — remove them
    shutil.rmtree(project_dir / ".github", ignore_errors=True)

    # Append our extra entries to files lake generated
    with open(project_dir / ".gitignore", "a") as f:
        f.write("/references/\n")
    with open(project_dir / ".gitattributes", "a") as f:
        f.write("*.jsonl merge=union\n")

    # Write custom files
    today = date.today()

    files: dict[str, str] = {
        "LICENSE": build_apache_license(today.year, author),
        "CLAUDE.md": CLAUDE_MD,
        "AGENTS.md": AGENTS_MD,
        ".mcp.json": MCP_JSON,
    }

    for rel_path, content in files.items():
        path = project_dir / rel_path
        path.write_text(substitute(content, name))
        print(f"  wrote {rel_path}")

    # Create GitHub remote before bd init so beads can find the upstream
    has_remote = False
    if visibility == "local":
        pass  # no remote
    elif shutil.which("gh") is None:
        print(
            "\nNote: 'gh' not found — skipping GitHub step.\n"
            "To create the repo manually:\n"
            f"  cd {project_dir}\n"
            f"  gh repo create {name} --{visibility} --source=. --remote=origin --push"
        )
    else:
        print(f"\nCreating GitHub repo ({visibility}) …")
        has_remote = run(
            ["gh", "repo", "create", name, f"--{visibility}",
             "--source=.", "--remote=origin"],
            cwd=project_dir,
        )
        if not has_remote:
            print(
                "Warning: gh repo create failed.\n"
                "You can retry manually:\n"
                f"  cd {project_dir}\n"
                f"  gh repo create {name} --{visibility} --source=. --remote=origin --push",
                file=sys.stderr,
            )

    # Initial commit + push before bd init so beads finds a tracking upstream
    run(["git", "add", "."], cwd=project_dir)
    run(["git", "commit", "-m", f"Initial scaffold for {name}"], cwd=project_dir)
    if has_remote:
        run(["git", "push", "-u", "origin", "HEAD"], cwd=project_dir)

    # beads task tracker (after push so git tracking branch exists)
    print("\nInitialising beads task tracker …")
    run(["bd", "init"], cwd=project_dir)

    # Second commit for beads files generated by bd init
    run(["git", "add", "."], cwd=project_dir)
    run(["git", "commit", "-m", "Initialise beads task tracker", "--allow-empty"], cwd=project_dir)
    if has_remote:
        run(["git", "push", "origin", "HEAD"], cwd=project_dir)

    # Register
    registry_add(name, project_dir)

    print(f"\nDone!  Project created at:\n  {project_dir}\n")


def cmd_list() -> None:
    reg = registry_load()
    if not reg:
        print("No projects managed by this tool yet.")
        return
    stale = [name for name, path in reg.items() if not Path(path).exists()]
    for name in stale:
        print(f"Note: {reg[name]} not found — removing stale entry '{name}'.", file=sys.stderr)
        registry_remove(name)
        del reg[name]
    if not reg:
        print("No projects managed by this tool yet.")
        return
    for name, path in sorted(reg.items()):
        print(f"{name}\t{path}")


def cmd_delete(name: str) -> None:
    reg = registry_load()
    if name not in reg:
        print(f"Error: no project named '{name}' in the registry.", file=sys.stderr)
        sys.exit(1)

    project_dir = Path(reg[name])

    # If the directory no longer exists, just purge the registry entry.
    if not project_dir.exists():
        print(f"Project : {name}")
        print(f"Path    : {project_dir}")
        print("Note: directory not found — removing stale registry entry.")
        registry_remove(name)
        print("Done.")
        return

    # Confirm
    print(f"Project : {name}")
    print(f"Path    : {project_dir}")
    remote = get_github_remote(project_dir)
    if remote:
        print(f"Remote  : {remote}")
    suffix = " and GitHub repo" if remote else ""
    answer = input(f"\nPermanently delete local directory{suffix}? [y/N]: ").strip().lower()
    if answer != "y":
        print("Aborted.")
        return

    # Delete GitHub repo
    if remote:
        if shutil.which("gh") is None:
            print(
                "Note: 'gh' not found — cannot delete GitHub repo automatically.\n"
                f"Delete it manually at: {remote}"
            )
        else:
            print("Deleting GitHub repo …")
            ok = run(["gh", "repo", "delete", name, "--yes"])
            if not ok:
                print(
                    "Warning: GitHub repo deletion failed.\n"
                    "You may need to grant the delete_repo scope:\n"
                    "  gh auth refresh -h github.com -s delete_repo\n"
                    f"Then: gh repo delete {name} --yes",
                    file=sys.stderr,
                )

    # Delete local directory
    print(f"Deleting {project_dir} …")
    shutil.rmtree(project_dir)

    # Remove from registry
    registry_remove(name)
    print("Done.")


COMPLETION_SCRIPT = dedent("""\
    # research shell completion

    # Shell wrapper: intercepts 'research cd' to actually change directory.
    # All other subcommands are passed through to the binary unchanged.
    research() {
        if [[ $1 == cd ]]; then
            local dir
            dir=$(command research cd "$2") && builtin cd "$dir"
        else
            command research "$@"
        fi
    }

    _research_complete() {
        local -a subcmds projects
        subcmds=(new list delete cd rename completion)
        if [[ $CURRENT -eq 2 ]]; then
            compadd -a subcmds
        elif [[ $CURRENT -eq 3 && ( $words[2] == delete || $words[2] == cd || $words[2] == rename ) ]]; then
            projects=($(command research list 2>/dev/null | awk '{print $1}'))
            compadd -a projects
        fi
    }
    compdef _research_complete research
""")

COMPLETION_EVAL_LINE = 'eval "$(research completion)"'


def cmd_rename(old_name: str, new_name: str) -> None:
    reg = registry_load()
    if old_name not in reg:
        print(f"Error: no project named '{old_name}' in the registry.", file=sys.stderr)
        sys.exit(1)
    if new_name in reg:
        print(f"Error: '{new_name}' already exists in the registry.", file=sys.stderr)
        sys.exit(1)

    project_dir = Path(reg[old_name])

    if not project_dir.exists():
        print(f"Note: {project_dir} not found — removing stale registry entry.", file=sys.stderr)
        registry_remove(old_name)
        sys.exit(1)

    new_dir = project_dir.parent / new_name
    if new_dir.exists():
        print(f"Error: {new_dir} already exists.", file=sys.stderr)
        sys.exit(1)

    remote = get_github_remote(project_dir)

    # Rename local directory
    print(f"Renaming {project_dir} → {new_dir} …")
    project_dir.rename(new_dir)

    # Rename GitHub repo (remote URL still points to old name after local rename)
    if remote:
        if shutil.which("gh") is None:
            print(
                "Note: 'gh' not found — cannot rename GitHub repo automatically.\n"
                f"Rename it manually at: {remote}"
            )
        else:
            print(f"Renaming GitHub repo to {new_name} …")
            ok = run(["gh", "repo", "rename", new_name, "-y"], cwd=new_dir)
            if not ok:
                print("Warning: GitHub repo rename failed.", file=sys.stderr)

    # Update registry
    registry_remove(old_name)
    registry_add(new_name, new_dir)

    print("Done.")
    print(f"Note: Lean source files still reference '{old_name}' — update lakefile.toml and .lean files if needed.")


def cmd_cd(name: str) -> None:
    reg = registry_load()
    if name not in reg:
        print(f"Error: no project named '{name}' in the registry.", file=sys.stderr)
        sys.exit(1)
    project_dir = Path(reg[name])
    if not project_dir.exists():
        print(f"Note: {project_dir} not found — removing stale registry entry.", file=sys.stderr)
        registry_remove(name)
        sys.exit(1)
    print(project_dir)


def cmd_completion(install: bool = False) -> None:
    if not install:
        print(COMPLETION_SCRIPT)
        return

    zshrc = Path("~/.zshrc").expanduser()
    if zshrc.exists() and COMPLETION_EVAL_LINE in zshrc.read_text():
        print("Shell completion already configured in ~/.zshrc.")
        return
    with zshrc.open("a") as f:
        f.write(f"\n{COMPLETION_EVAL_LINE}\n")
    print("Shell completion added to ~/.zshrc.")
    print("Reload your shell or run:  source ~/.zshrc")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

USAGE = """\
Usage:
  research new                  scaffold a new project (interactive)
  research list                 list all managed projects
  research cd NAME              cd to a project directory
  research rename OLD NEW       rename a project (directory + GitHub repo)
  research delete NAME          delete a project (local + GitHub)
  research completion           print shell completion script
  research completion install   add completion to ~/.zshrc
"""


def main() -> None:
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(USAGE)
        return

    cmd = args[0]

    if cmd == "new":
        cmd_new(args[1] if len(args) > 1 else "")
    elif cmd == "list":
        cmd_list()
    elif cmd == "rename":
        if len(args) < 3:
            print("Usage: research rename OLD NEW", file=sys.stderr)
            sys.exit(1)
        cmd_rename(args[1], args[2])
    elif cmd == "cd":
        if len(args) < 2:
            print("Usage: research cd NAME", file=sys.stderr)
            sys.exit(1)
        cmd_cd(args[1])
    elif cmd == "delete":
        if len(args) < 2:
            print("Usage: research delete NAME", file=sys.stderr)
            sys.exit(1)
        cmd_delete(args[1])
    elif cmd == "completion":
        cmd_completion(install=len(args) > 1 and args[1] == "install")
    else:
        print(f"Unknown command: {cmd!r}\n{USAGE}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
